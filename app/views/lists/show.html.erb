<div class="banner" style="background-image: linear-gradient(rgba(0,0,0,0.4),rgba(0,0,0,0.4)), url(https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/background.png);">
  <div class="container">
    <h1><%= @list.name %></h1>
    <p><%= link_to "Add movie to this list", new_list_bookmark_path(@list), class: "btn btn-primary" %></p>
  </div>
</div>



<div class="d-flex flex-wrap gap-3 justify-content-center align-items-center m-4">
  <% @list.bookmarks.each do |bookmark| %>
  <% movie_data = bookmark.movie.fetch_api %>
    <div class="card-trip rounded-3 ">
      <% p movie_data %>
      <img src=<%= movie_data["Poster"]  %>>
      <div class="card-trip-infos">
        <div>
          <h2><%= link_to bookmark.movie.title %></h2>
          <p> <%= bookmark.comment %> </p>
        </div>
        <h2 class="card-trip-pricing"><%= link_to "Delete", list_bookmark_path(@list, bookmark), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %></h2>
      </div>
    </div>
  <% end %>
</div>

<p>what a nice list</p>
<p><%= link_to "Add movie to this list", new_list_bookmark_path(@list) %></p>

<p><%= link_to "Return to lists", lists_path %></p>
