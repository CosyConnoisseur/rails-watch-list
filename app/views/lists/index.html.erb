
<div class="banner" style="background-image: linear-gradient(rgba(0,0,0,0.4),rgba(0,0,0,0.4)), url('<%= @banner %>');">
  <div class="container d-flex flex-column align-items-center justify-content-center">
    <h1>Your Movie Collections</h1>
    <p><%= link_to "Add new list", new_list_path, class: "btn btn-primary" %></p>
  </div>
</div>


<div class="d-flex flex-wrap gap-3 justify-content-center align-items-center m-4">
  <% @lists.each do |list| %>
  <%# <% if list.photo.attached? %>
    <%# <%= cl_image_tag list.photo.key, class: "card-img-top rounded-4" %>
    <%# <% elsif @movie_lists[list.name] %>
    <%= link_to list_path(list.id), class: "d-block" do %>
      <div class="card-trip rounded-4">
        <img src="<%= @movie_lists[list.name] %>">
        <div class="card-trip-infos">
          <div>
            <h2><%= list.name %></h2>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
  <%# <% end %>
</div>

<p>All movies go here</p>
<ul>
  <% @all_movies.each do |movie| %>
  <li><%= link_to movie.title %></li>
  <% end %>
</ul>
