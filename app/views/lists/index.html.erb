<h1>Lists index</h1>
<p>Lists go here</p>
<p><%= link_to "Add new list", new_list_path %></p>
<ul>
  <% @lists.each do |list| %>
  <li><%= link_to list.name, list_path(list.id) %></li>
  <% end %>
</ul>

<p>All movies go here</p>
<ul>
  <% @all_movies.each do |movie| %>
  <li><%= link_to movie.title %></li>
  <% end %>
</ul>
